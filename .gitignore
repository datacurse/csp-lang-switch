# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
*.egg-info/
build/
dist/

# PyInstaller intermediate; the spec itself IS tracked
*.spec.cache

# Virtual environments
.venv/
venv/
env/

# Per-language data trees — copyrighted CSP data + regenerable patched copies.
# Kept on disk, never committed. Layout, one folder per language:
#   langs/<lang>/ui/         — GUID-named resource files (main UI)
#   langs/<lang>/plugins/    — filter plug-in DLLs
#   langs/<lang>/tools/      — tool-palette SQLite DBs
#   langs/<lang>/materials/  — material catalog + per-pack files
# langs/english/ is the untouched stock CSP snapshot; langs/russian/ is the
# patched build; langs/japanese/ui/ is the translation oracle.
langs/

# Claude Code per-machine settings (.claude/settings.json IS tracked)
.claude/settings.local.json

# Per-machine state for src/lang.py — caches current per-pipeline language
# (russian / original / unknown) + a content fingerprint of the install.
.lang-state.json

# Editor / IDE
.idea/
*.swp
*~

# OS cruft
.DS_Store
Thumbs.db
desktop.ini

