# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
*.egg-info/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# Patched resource files generated by `repack.py apply` — the russian build
# (regenerable from a resource file + a translation CSV)
russian/

# Claude Code per-machine settings (.claude/settings.json IS tracked)
.claude/settings.local.json

# Per-machine state for src/lang.py — caches current per-pipeline language
# (russian / original / unknown) + a content fingerprint of the install.
.lang-state.json

# Editor / IDE
.idea/
*.swp
*~

# OS cruft
.DS_Store
Thumbs.db
desktop.ini

# CSP resource binaries — copyrighted + large; kept on disk, not committed.
# Untracked with `git rm --cached` (the local files are not deleted).
resource/

# Scratch dir for the plugin-DLL spike — patched copies of copyrighted DLLs.
spike/

# Filter plug-in DLLs — copyrighted; originals (plugins/) + Russian build
# (russian-plugins/). Kept on disk, not committed. Managed by src/plugins.py.
plugins/
russian-plugins/

# Tool-palette SQLite DBs — copyrighted; originals (tools/) + Russian build
# (russian-tools/). Kept on disk, not committed. Managed by src/tools.py.
tools/
russian-tools/

# Material-catalog SQLite DB — copyrighted; original (materials/) + Russian
# build (russian-materials/). Kept on disk, not committed. Via src/materials.py.
materials/
russian-materials/
