# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
*.egg-info/
build/
dist/

# PyInstaller intermediate; the spec itself IS tracked
*.spec.cache

# Virtual environments
.venv/
venv/
env/

# Per-language data trees — copyrighted CSP data + regenerable patched copies.
# Kept on disk, never committed. Layout under versions/<csp-version>/langs/:
#   english/    — stock CSP snapshot (ui, plugins)
#   japanese/   — translation oracle (ui/)
#   russian/    — patched community build
versions/*/langs/

# Claude Code per-machine settings (.claude/settings.json IS tracked)
.claude/settings.local.json

# Per-machine state for src/lang.py — caches current per-pipeline language
# (russian / original / unknown) + a content fingerprint of the install.
.lang-state.json
.csp-lang-switch-settings.json
.csp-lang-settings.json

# Editor / IDE
.idea/
*.swp
*~

# OS cruft
.DS_Store
Thumbs.db
desktop.ini

