# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
*.egg-info/
build/
dist/

# PyInstaller intermediate; the spec itself IS tracked
*.spec.cache

# Virtual environments
.venv/
venv/
env/

# The Russian build tree: regenerable patched copies of CSP's own data
# (resource files, plug-in DLLs, tool DBs, material catalog). Layout:
#   russian/ui/         — patched GUID-named resource files (main UI)
#   russian/plugins/    — patched filter DLLs
#   russian/tools/      — patched tool-palette SQLite DBs
#   russian/materials/  — patched material catalog + per-pack files
russian/

# Untouched per-machine snapshots of the live CSP install's plug-ins, tools,
# and material catalog. Taken once by `*.py backup` and used by `*.py restore`.
#   originals/plugins/   /tools/   /materials/
# Copyrighted + machine-specific; kept on disk, never committed.
originals/

# Claude Code per-machine settings (.claude/settings.json IS tracked)
.claude/settings.local.json

# Per-machine state for src/lang.py — caches current per-pipeline language
# (russian / original / unknown) + a content fingerprint of the install.
.lang-state.json

# Editor / IDE
.idea/
*.swp
*~

# OS cruft
.DS_Store
Thumbs.db
desktop.ini

# CSP resource binaries — copyrighted + large; kept on disk, not committed.
# Untracked with `git rm --cached` (the local files are not deleted).
resource/

